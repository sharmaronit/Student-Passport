# ============================================
# Student Skill Passport — Environment Variables
# Copy this to .env and fill in your values
# ============================================

# --- PostgreSQL ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=skillpassport
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgres://postgres:your_secure_password_here@postgres:5432/skillpassport?sslmode=disable

# --- Go API Server ---
API_PORT=8080
API_ENV=development
JWT_SECRET=your-jwt-secret-at-least-32-characters-long

# --- Polygon Blockchain ---
POLYGON_RPC_URL=https://rpc-amoy.polygon.technology/
POLYGON_CHAIN_ID=80002
# Private key of the backend wallet (for sending transactions)
# NEVER commit a real private key. Use a testnet-only wallet.
BACKEND_WALLET_PRIVATE_KEY=0xYOUR_TESTNET_PRIVATE_KEY_HERE

# --- Smart Contract Addresses (filled after deployment) ---
ISSUER_REGISTRY_ADDRESS=0x0000000000000000000000000000000000000000
SKILL_CREDENTIAL_ADDRESS=0x0000000000000000000000000000000000000000
REVOCATION_REGISTRY_ADDRESS=0x0000000000000000000000000000000000000000

# --- Pinata (IPFS) ---
PINATA_API_KEY=your_pinata_api_key
PINATA_SECRET_KEY=your_pinata_secret_key
PINATA_GATEWAY_URL=https://gateway.pinata.cloud/ipfs

# --- Hardhat (for contract deployment) ---
POLYGONSCAN_API_KEY=your_polygonscan_api_key
